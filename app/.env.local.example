## Local environment variables (copy to .env.local)
#
# NOTE:
# - Do NOT commit real secrets.
# - In production (Vercel), set these in Project Settings → Environment Variables.
#
# Optional: production canonical hostname (HTTPS redirect). Omit locally, or set
# ROM_SKIP_CANONICAL_REDIRECT=1 if sign-in breaks during local `next start`.
# ROM_CANONICAL_HOST="www.example.com"
# ROM_SKIP_CANONICAL_REDIRECT="1"

# Used to hash OTP codes (pepper) and sign session cookies.
ROM_OTP_PEPPER="dev-change-me"
ROM_SESSION_SECRET="dev-change-me-too"

# Resend (email OTP delivery)
# Create an API key in Resend, then set:
RESEND_API_KEY="re_..."
# Use a verified sender/domain in Resend, e.g. "no-reply@report-o-matic.online"
ROM_FROM_EMAIL="no-reply@report-o-matic.online"

# Optional: how long the sign-in code stays valid (seconds). Default is 180 in production
# NODE_ENV and 600 in dev. Use 600 for 10 minutes while testing with `npm run start`.
# ROM_OTP_TTL_SECONDS="600"

# Supabase (OTP challenges + future multi-tenant data)
# Create a project at https://supabase.com → Settings → API
SUPABASE_URL="https://xxxx.supabase.co"
# Server-only: never expose in the browser or client bundles
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
# Optional for now (needed when the browser talks to Supabase directly)
# SUPABASE_ANON_KEY="eyJ..."

# OpenAI — school report AI drafts (server-only)
# OPENAI_API_KEY="sk-..."
# Optional model (default gpt-4o-mini)
# OPENAI_MODEL="gpt-4o-mini"

# In production you will set these (later):
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# SaaS-owner Finance card — estimated VAT on recorded “payments in” (informational only)
# Shown by default. Set ROM_VAT_ESTIMATE=0 (or false/off/no) to hide the block.
# ROM_VAT_BASIS="inclusive"
# ROM_VAT_DISPLAY_CURRENCY="EUR"
# ROM_VAT_ESTIMATE="0"
#
# Retail pack pricing & customer-facing tax (Spain default: 21% IVA)
# - ROM_VAT_RATE_PERCENT or ROM_TAX_RATE_PERCENT: VAT/IVA rate for packs + finance estimate (default 21).
# - ROM_PACK_PRICE_TAX_BASIS: exclusive (default) = credit_packs.price_cents is BEFORE tax; customer pays net * (1 + rate). inclusive = price_cents is all-in.
# - ROM_SALES_TAX_LABEL: short label in UI and Stripe line item, e.g. IVA, VAT, TVA.
# ROM_VAT_RATE_PERCENT="21"
# ROM_PACK_PRICE_TAX_BASIS="exclusive"
# ROM_SALES_TAX_LABEL="IVA"

